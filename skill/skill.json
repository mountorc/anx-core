{
  "name": "anx-core-skill",
  "version": "1.0.0",
  "description": "ANX Core Skill - Provides API capabilities for ANX markup output and CLI execution",
  "author": "ANX Team",
  "license": "MIT",
  "main": "index.js",
  "keywords": ["anx", "core", "skill", "api", "cli", "markup"],
  "triggers": {
    "description": "When user needs to work with ANX format, convert ANX to Markdown/Markup, execute CLI commands, or generate node visualizations",
    "keywords": ["anx", "convert", "markup", "cli", "command", "visualization", "node", "form", "parse", "tile"]
  },
  "capabilities": [
    {
      "name": "convertAnxToMarkup",
      "description": "Convert ANX content to Markup format by uuid_tile",
      "parameters": {
        "uuid_tile": { "type": "string", "description": "UUID of the ANX tile", "required": true }
      }
    },
    {
      "name": "executeCliCommand",
      "description": "Execute ANX CLI commands",
      "parameters": {
        "command": { "type": "string", "description": "CLI command string to execute", "required": true }
      }
    }
  ],
  "config": {
    "backendUrl": {
      "type": "string",
      "default": "http://localhost:7887",
      "description": "Backend service URL"
    }
  },
  "dependencies": {
    "node-fetch": "^3.3.2"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "compatibleWith": ["openclaw", "trae", "claude-code"]
}
